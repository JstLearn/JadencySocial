# =============================================
# JADENCYSOCIAL AUTONOMOUS SYSTEM
# Environment Configuration Template
# =============================================

# =============================================
# API KEYS
# =============================================

# Apify - Google Maps, Yelp scraping
APIFY_API_KEY=

# SerpAPI - Google search
SERPAPI_API_KEY=

# Firecrawl - Website crawl & SEO analiz
FIRECRAWL_API_KEY=

# Google Maps / Places API (opsiyonel - Apify yeterli)
GOOGLE_MAPS_API_KEY=

# Anthropic (Claude API) (REQUIRED for AI agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stripe (REQUIRED for payments)
STRIPE_SECRET_KEY=your_stripe_test_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Twilio (REQUIRED for calls/SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+15551234567

# ElevenLabs (REQUIRED for voice/TTS)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Resend Email (REQUIRED for email sending)
RESEND_API_KEY=your_resend_api_key_here

# =============================================
# DATABASE
# =============================================

DATABASE_PATH=./data/jadency.db

# =============================================
# TELEGRAM NOTIFICATIONS (REQUIRED)
# =============================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# =============================================
# GITHUB (for deployments)
# =============================================

GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=jadency-social

# =============================================
# APPLICATION SETTINGS
# =============================================

NODE_ENV=development
LOG_LEVEL=info

# Scout settings
SCOUT_DAILY_LIMIT=100
SCOUT_RADIUS_KM=10

# Call settings
CALL_DAILY_LIMIT=30
CALL_RETRY_ATTEMPTS=3

# Proposal settings
PROPOSAL_VALIDITY_DAYS=14
PROPOSAL_DEFAULT_CONTRACT_LENGTH=12

# Company info (used in proposals/invoices)
COMPANY_NAME=Jadency Social
COMPANY_EMAIL=info@jadencysocial.com
COMPANY_PHONE=+905551234567
COMPANY_ADDRESS=Tekirdağ, Türkiye