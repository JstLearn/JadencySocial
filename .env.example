# Cloudflare Tunnel Token
# Cloudflare Dashboard > Zero Trust > Networks > Tunnels > Create Tunnel (Token)
CLOUDFLARE_TUNNEL_TOKEN=

# =============================================
# E-POSTA YAPILANDIRMASI (Mailgun/Özel SMTP)
# =============================================
# Gelen Sunucu (IMAP): mail.jadencysocial.com:993
# Giden Sunucu (SMTP): mail.jadencysocial.com:587
# POP3: mail.jadencysocial.com:110
# Webmail: https://panel.veriupmail.com

# SMTP Settings (e-posta gönderimi için)
SMTP_HOST=mail.jadencysocial.com
SMTP_PORT=587
SMTP_USER=hello@jadencysocial.com
SMTP_PASS=Mail_Sifreniz
SMTP_FROM=hello@jadencysocial.com
SMTP_FROM_NAME=JadencySocial

# IMAP Settings (e-posta alımı için - opsiyonel)
IMAP_HOST=mail.jadencysocial.com
IMAP_PORT=993
IMAP_USER=hello@jadencysocial.com
IMAP_PASS=Mail_Sifreniz

# =============================================
# CLOUDFLARE DNS AYARLARI
# =============================================
# Aşağıdaki DNS kayıtlarını Cloudflare Dashboard'da ekleyin:
#
# MX Record (Zorunlu - E-posta yönlendirme):
#   Name: @ | Content: mail.jadencysocial.com | Priority: 10 | TTL: Auto
#
# TXT Record (SPF - Gönderim yetkilendirme):
#   Name: @ | Content: v=spf1 mx ~all | TTL: Auto
#
# TXT Record (DKIM - Kimlik doğrulama):
#   Name: mail._domainkey | Content: (Cloudflare'dan alınacak public key) | TTL: Auto
#
# TXT Record (DMARC):
#   Name: _dmarc | Content: v=DMARC1; p=quarantine; rua=mailto:hello@jadencysocial.com | TTL: Auto
#
# CNAME (Webmail yönlendirme - opsiyonel):
#   Name: webmail | Content: panel.veriupmail.com | TTL: Auto
